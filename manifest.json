{
  "manifest_version": 3,
  "name": "RaccoonLagoon",
  "version": "2.0.0",
  "description": "Skicka bilder och videos till Discord via webhook.",

  "permissions": [
    "storage",
    "contextMenus",
    "sidePanel",
    "tabs"
  ],

  "host_permissions": [
    "https://www.instagram.com/*",
    "https://www.youtube.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": [
        "components/storage.js",
        "components/webhook.js",
        "components/icons.js",
        "content/instagram-content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": [
        "components/storage.js",
        "components/webhook.js",
        "components/icons.js",
        "content/youtube-content.js",
        "content/youtube-stream.js",
        "content/youtube-zoom.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },

  "action": {
    "default_title": "RaccoonLagoon"
  },

  "commands": {
    "open-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Öppna RaccoonLagoon side panel"
    }
  }
}
